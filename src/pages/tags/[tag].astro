---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/Layout.astro";
import Sidebar from "../../components/Sidebar.astro";
import NoteCard from "../../components/NoteCard.astro";

const allNotes = await getCollection("notes", ({ data }) => {
  return data.draft !== true;
});

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => {
    return data.draft !== true;
  });

  const tags = [...new Set(notes.flatMap((note) => note.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      notes: notes
        .filter((note) => note.data.tags.includes(tag))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag, notes } = Astro.props;
---

<BaseLayout title={`标签：${tag}`} description={`标签 ${tag} 下的笔记。`}>
  <main class="layout">
    <Sidebar notes={allNotes} />

    <section class="main-content">
      <section class="hero card">
        <p class="eyebrow">tag</p>
        <h1>标签：{tag}</h1>
        <p>共 {notes.length} 篇笔记。</p>
      </section>

      <div class="note-list">
        {notes.map((note) => <NoteCard note={note} />)}
      </div>
    </section>
  </main>
</BaseLayout>
