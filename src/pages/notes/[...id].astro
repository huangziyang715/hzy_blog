---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => {
    return data.draft !== true;
  });

  return notes.map((note) => ({
    params: { id: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const base = import.meta.env.BASE_URL;
const url = (path = "/") => {
  const basePath = base.replace(/\/$/, "");
  const cleanPath = path.replace(/^\/+/, "");
  return `${basePath}/${cleanPath}`;
};
const formattedDate = note.data.date.toLocaleDateString("zh-CN");
const categoryUrl = url(`/categories/${note.data.category}/`);
const tagUrl = (tag) => url(`/tags/${tag}/`);
---

<BaseLayout title={note.data.title} description={note.data.description}>
  <main class="layout">
    <aside class="sidebar">
      <section class="side-card card">
        <a class="back-link" href={url()}>← 返回首页</a>
      </section>

      <section class="side-card card">
        <h3>文章信息</h3>
        <p>{formattedDate}</p>
        <p><a class="inline-link" href={categoryUrl}>{note.data.category}</a></p>
      </section>

      <section class="side-card card">
        <h3>标签</h3>
        <div class="tag-cloud">
          {note.data.tags.map((tag) => <a class="tag" href={tagUrl(tag)}>{tag}</a>)}
        </div>
      </section>
    </aside>

    <article class="article card">
      <p class="article-meta">{formattedDate} · <a href={categoryUrl}>{note.data.category}</a></p>
      <h1>{note.data.title}</h1>
      <p class="article-description">{note.data.description}</p>

      <div class="article-content">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
