---
const { note } = Astro.props;

const base = import.meta.env.BASE_URL;
const basePath = base.replace(/\/$/, "");
const href = `${basePath}/notes/${note.id}/`;
const formattedDate = note.data.date.toLocaleDateString("zh-CN");
---

<article class="note-card card">
  <div class="note-meta">
    <span>{formattedDate}</span>
    <span>{note.data.category}</span>
  </div>

  <h2>
    <a href={href}>{note.data.title}</a>
  </h2>

  <p>{note.data.description}</p>

  <div class="note-tags">
    {note.data.tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
</article>
