---
const { notes = [] } = Astro.props;

const categories = [...new Set(notes.map((note) => note.data.category))];
const tags = [...new Set(notes.flatMap((note) => note.data.tags))];

const base = import.meta.env.BASE_URL;
const url = (path = "/") => {
  const basePath = base.replace(/\/$/, "");
  const cleanPath = path.replace(/^\/+/, "");
  return `${basePath}/${cleanPath}`;
};
const categoryUrl = (category) => url(`/categories/${category}/`);
const tagUrl = (tag) => url(`/tags/${tag}/`);
---

<aside class="sidebar">
  <section class="profile-card card">
    <div class="avatar">☀️</div>
    <h2>hello_world</h2>
    <p>这里会用来整理课程笔记、论文阅读和 PPT 及课本存储。</p>
  </section>

  <section class="side-card card">
    <h3>站点统计</h3>
    <div class="stats">
      <div class="stat">
        <strong>{notes.length}</strong>
        <span>文章</span>
      </div>
      <div class="stat">
        <strong>{categories.length}</strong>
        <span>分类</span>
      </div>
      <div class="stat">
        <strong>{tags.length}</strong>
        <span>标签</span>
      </div>
    </div>
  </section>

  <section class="side-card card">
    <h3>分类</h3>
    <div class="tag-cloud">
      {categories.map((category) => <a class="tag" href={categoryUrl(category)}>{category}</a>)}
    </div>
  </section>

  <section class="side-card card">
    <h3>标签</h3>
    <div class="tag-cloud">
      {tags.map((tag) => <a class="tag" href={tagUrl(tag)}>{tag}</a>)}
    </div>
  </section>
</aside>
